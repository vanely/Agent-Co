# ==============================================================================
# Agent Co — environment configuration
# ==============================================================================
# Copy to .env and fill in. Run `bin/agentco setup` to generate secrets + have
# the setup wizard populate what it can.
#
# Anything with a DEFAULT can be left blank; the system uses the default.
# Anything marked REQUIRED must be set before that feature works.
# Secrets should never be committed — .env is in .gitignore.
# ==============================================================================

# ─── Install location (auto-detected by setup CLI) ───────────────────────────
# AGENT_CO_ROOT is the absolute path to the installed agent-co directory.
# Default: the setup CLI sets this to where you installed. Most scripts resolve
# it from env or from their own location.
# AGENT_CO_ROOT=/path/to/agent-co

# ─── LLM provider ─────────────────────────────────────────────────────────────
# Which LLM backend powers the fleet. Options:
#   claude-cli       use the authenticated Claude Code CLI (subprocess exec;
#                    requires `claude` on PATH + local auth)
#   anthropic-api    direct Anthropic API (requires ANTHROPIC_API_KEY)
#   openai-api       OpenAI-compatible API (requires OPENAI_API_KEY)
#   ollama           local Ollama (requires OLLAMA_HOST; defaults localhost:11434)
# Default: claude-cli
LLM_PROVIDER=claude-cli

# API keys for non-CLI providers. Only set the one matching your LLM_PROVIDER.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OLLAMA_HOST=http://localhost:11434

# Model for provider. Defaults chosen to be sensible per provider.
# LLM_MODEL=claude-opus-4-7        # for claude-cli / anthropic-api
# LLM_MODEL=gpt-4o                 # for openai-api
# LLM_MODEL=llama3.1:70b           # for ollama

# ─── Postgres (runs in Docker by default) ─────────────────────────────────────
POSTGRES_DB=agentco
POSTGRES_USER=agentco
# REQUIRED — setup CLI generates a strong default if you leave blank
POSTGRES_PASSWORD=

# Connection URL used by the relay. Keep in sync with the three vars above.
RELAY_POSTGRES_URL=postgresql://agentco:${POSTGRES_PASSWORD}@localhost:5432/agentco

# ─── Relay server (host process) ──────────────────────────────────────────────
RELAY_PORT=3456
# Optional bearer token for relay API. Blank = no auth (fine for localhost dev).
# For any networked deploy, set a strong random value.
RELAY_SECRET=

# ─── n8n (workflow engine, runs in Docker) ────────────────────────────────────
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin@agentco.local
# REQUIRED — pick a strong password
N8N_BASIC_AUTH_PASSWORD=
# CRITICAL: never change after first run; changing invalidates all stored
# credentials. Setup CLI generates a 64-char hex string.
N8N_ENCRYPTION_KEY=

# Database connection for n8n (points at the Docker postgres service name).
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=${POSTGRES_DB}
DB_POSTGRESDB_USER=${POSTGRES_USER}
DB_POSTGRESDB_PASSWORD=${POSTGRES_PASSWORD}

# Owner account for n8n UI (set once during first-run). Required if
# N8N_BASIC_AUTH_ACTIVE=true.
N8N_OWNER_EMAIL=admin@agentco.local
N8N_OWNER_PASSWORD=

# API key for programmatic access to n8n (generated during n8n first-run).
# Leave blank initially; setup CLI populates after n8n boots.
N8N_API_KEY=

# Re-enable Execute Command node (disabled by default in n8n v2).
NODES_EXCLUDE=[]
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# Host-gateway mapping for n8n to reach the relay at localhost.
# Linux: n8n's "host.docker.internal" is mapped via extra_hosts in compose.
# macOS/Windows: Docker Desktop resolves host.docker.internal natively.
CLAUDE_RELAY_URL=http://host.docker.internal:${RELAY_PORT}

# Execution behavior.
EXECUTIONS_TIMEOUT=3600
EXECUTIONS_TIMEOUT_MAX=7200
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_SUCCESS=all
EXECUTIONS_DATA_MAX_AGE=168

# ─── Dashboard (optional, Docker profile=monitoring) ─────────────────────────
DASHBOARD_PORT=3001
DASHBOARD_USER=admin
# REQUIRED if dashboard is enabled
DASHBOARD_PASSWORD=
# REQUIRED — setup CLI generates a 64-char hex string
JWT_SECRET=

# ─── Discord bot (optional) ───────────────────────────────────────────────────
# Get a bot token at https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=
# Comma-separated channel IDs the bot listens to. Blank = all channels.
# DISCORD_CHANNEL_IDS=
# Webhook URL the bot forwards to (usually n8n's discord-gateway webhook).
# N8N_DISCORD_WEBHOOK_URL=http://localhost:5678/webhook/discord-message

# ─── Telegram bot (optional) ──────────────────────────────────────────────────
# Get a bot token from @BotFather
# TELEGRAM_BOT_TOKEN=
# Your personal chat ID (find via @userinfobot)
# TELEGRAM_CHAT_ID=

# ─── Outbound email (optional, SMTP) ──────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-account@gmail.com
# SMTP_PASS=                        # Gmail: 16-char app password, spaces removed
# SMTP_FROM_NAME=Agent Co

# ─── Operational limits ───────────────────────────────────────────────────────
EMAIL_DAILY_CAP=100
EMAIL_BATCH_WAIT_SECONDS=30
MAX_FOLLOWUP_STEPS=3
SCRAPE_CHECK_WINDOW_HOURS=24
BACKUP_RETENTION_DAYS=7
HEARTBEAT_CRON_MINUTES=60
AGENTCO_IDLE_THRESHOLD_HOURS=3

# ─── Telegram voice/audio transcription ───────────────────────────────────────
# The Telegram bot accepts images, voice messages, and audio files. Images
# are referenced by path so Claude can inspect them via the Read tool.
# Voice/audio is transcribed via Whisper — pick one provider:
#   - GROQ_API_KEY (preferred): free tier, very fast, whisper-large-v3-turbo.
#     Sign up at https://console.groq.com
#   - OPENAI_API_KEY (fallback): paid (~$0.006/min), whisper-1.
# If neither is set, audio attachments arrive with a "no transcription
# provider configured" note and Claude can ask the user to retype.
GROQ_API_KEY=
# OPENAI_API_KEY=

# ─── System ───────────────────────────────────────────────────────────────────
TZ=America/New_York
